# ==============================================================================
# 🚀 VIDEO GENERATOR - EXAMPLE ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual API keys.
# ==============================================================================

# 🔑 API CREDENTIALS
# ------------------------------------------------------------------------------
# Openverse: Free CC-licensed images, no API key required
# Set to 'false' to disable Openverse image fallback
OPENVERSE_ENABLED=true

# AI Visual Verification: After downloading, checks if the media matches keywords
# Uses Ollama (moondream) or Gemini Vision. Set to 'false' to skip verification.
MEDIA_VERIFICATION_ENABLED=true
# Minimum confidence score (1-10) required to pass verification
MEDIA_VERIFICATION_CONFIDENCE=6

# Pexels API: Recommended (Primary source for high-quality stock footage)
# Get a free key at: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API: Optional (Image/video FALLBACK — NOT used for audio/music)
# NOTE: Pixabay has NO public audio endpoint (403). The music system uses
# the free ccMixter API, bundled MP3s, and procedural generation instead.
# Get a free key at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# 🎵 MUSIC SYSTEM (free, no API keys needed)
# ------------------------------------------------------------------------------
# The music system resolves background tracks using a priority chain:
#   1. bundled    — 5 ambient MP3s shipped with the repo (always works offline)
#   2. local      — tracks you drop in input/bgm/
#   3. ccmixter   — real CC-licensed music, free, no key needed
#   4. internet-archive — public domain audio (free, no key)
#   5. procedural — ffmpeg-generated tones (always works)
#
# Enable/disable (default: true): MUSIC_ENABLED=true
# Cache dir (relative root): MUSIC_CACHE_DIR=workspace/cache/free-music
# Provider timeout in ms: MUSIC_PROVIDER_TIMEOUT=15000
# Parallel search: MUSIC_PARALLEL=true

# Gemini API: Optional (Used for AI Director dynamic keyword optimization)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=30000
# GEMINI_MAX_RETRIES=2
# GEMINI_MAX_CONCURRENCY=2

# Local Ollama AI: Optional (Alternative to Gemini, no API key needed)
# Set AI_PROVIDER to 'gemini' or 'ollama' (default: ollama)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream:latest
# Alternative Ollama URL for the agentic brain (defaults to OLLAMA_BASE_URL)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_TIMEOUT_MS=120000
# OLLAMA_MAX_RETRIES=2
# OLLAMA_MAX_CONCURRENCY=2
# OLLAMA_AUTOPULL=true
# OLLAMA_AUTOSTART=true
# OLLAMA_SCRIPT_MODEL=llama3.2

# OpenRouter: Optional AI backend for the agentic brain (no local GPU needed)
# Get a key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# Agentic brain timeout (ms) for LLM calls
# BRAIN_TIMEOUT_MS=20000


# 🌐 SERVER SETTINGS
# ------------------------------------------------------------------------------
# Default port for the local asset/API server (default: 3001)
PORT=3001
# AVG_PORT takes priority over PORT when both are set (isolates from ambient PORT)
# AVG_PORT=3001
# Set to '1' to allow ambient PORT from the shell (default: ignored)
# AVG_PORT_IGNORE_ENV=0

# Bind address (default: 127.0.0.1 — local only)
# HOST=127.0.0.1

# CORS allowed origins (comma-separated, default: same-origin only)
# ALLOWED_ORIGINS=https://your-domain.example

# Set to '1' when running behind a reverse proxy (trusts X-Forwarded-* headers)
# TRUST_PROXY=0

# Expose health check details on /health (default: local requests only)
# EXPOSE_HEALTH_DETAILS=0

# Maximum concurrent video generation jobs (default: 1)
# MAX_CONCURRENT_JOBS=1

# Enable unsafe MCP tools (file delete, etc.) — local dev only
# ALLOW_UNSAFE_MCP_TOOLS=0
# Allow admin routes from non-local IPs (GET/HEAD only)
# ALLOW_UNSAFE_REMOTE_ADMIN=0

# Recommended when deploying the portal publicly.
# Used for canonical URLs, sitemap.xml, robots.txt, and social metadata.
PUBLIC_BASE_URL=https://your-domain.example


# 🎬 DEFAULT VIDEO SPECIFICATIONS
# ------------------------------------------------------------------------------
# Default orientation (options: 'landscape' for 16:9 or 'portrait' for 9:16)
VIDEO_ORIENTATION=landscape

# AI Voice ID (Edge-TTS Neural Voice)
# 👨 Male: en-US-GuyNeural, en-US-ChristopherNeural, en-GB-RyanNeural, en-IN-PrabhatNeural
# 👩 Female: en-US-JennyNeural, en-US-AriaNeural, en-US-SaraNeural, en-GB-SoniaNeural
VIDEO_VOICE=en-US-GuyNeural


# 🔊 TEXT-TO-SPEECH PROVIDERS
# ------------------------------------------------------------------------------
# Options: 'edge-tts', 'voicebox', 'xtts', 'openai-local'
# TTS_PROVIDER=edge-tts

# Custom path to the edge-tts executable (auto-detected if not set)
# EDGE_TTS_PATH=

# ──────────────────────────────────────────────────────────────────────────────
# 🗣️ VOICEBOX — Local GPU Voice Cloning & Narration
# ──────────────────────────────────────────────────────────────────────────────
# Jamie Pine's Voicebox (MIT, https://github.com/jamiepine/voicebox) is a
# free, local, GPU-accelerated voice studio. It bundles 7 TTS engines behind
# a REST API. The pipeline can auto-start it on demand.
#
# PREREQUISITES (one-time setup, see docs/VOICEBOX_SETUP.md):
#   1. git clone https://github.com/jamiepine/voicebox.git to a local dir
#   2. Create venv + install deps (incl. CUDA pytorch)
#   3. Register a voice profile (clone your voice or use a Kokoro preset)
#
# SAFETY NOTE: The vars below are safe to commit to .env.example EXCEPT
# VOICEBOX_PROFILE_ID (it's a local credential — don't share your profile).
# ==============================================================================

# --- TTS Provider ---
# Set to 'voicebox' to enable Voicebox synthesis.
# Other options: 'edge-tts' (default, works out of box), 'xtts', 'openai-local'
# TTS_PROVIDER=voicebox

# --- API Connection ---
# Base URL of the Voicebox server (default: http://127.0.0.1:17493)
# The pipeline auto-starts Voicebox when this port isn't answering.
VOICEBOX_API_URL=http://127.0.0.1:17493

# --- Voice Profile ---
# REQUIRED when TTS_PROVIDER=voicebox. This is the UUID of your cloned voice
# profile (or a Kokoro preset profile). Create one via:
#   curl -X POST http://127.0.0.1:17493/profiles -H "Content-Type: application/json" \
#     -d '{"name":"My Voice","voice_type":"cloned","default_engine":"chatterbox_turbo"}'
# OR via the bundled script:
#   node scripts/setup-voicebox-clone.mjs <your-voice.wav> "<transcript>"
# ⚠️ WARNING: treat this like a password — anyone with it can use your voice
# while your Voicebox server is running. Do NOT commit the real value.
# VOICEBOX_PROFILE_ID=<your-profile-uuid-here>

# --- Engine Selection ---
# Which TTS engine to use for narration. Options:
#   chatterbox_turbo  — Fast clone engine (~3.8 GB VRAM, best quality)
#   chatterbox        — Multilingual clone (~3.2 GB VRAM)
#   kokoro            — Default narrator, presets only, no clone (~0.8 GB VRAM)
#   qwen-3-tts        — High quality narrator (~3.6 GB VRAM, needs >4 GB VRAM)
# VOICEBOX_ENGINE=chatterbox_turbo

# --- Port (optional override) ---
# Defaults to 17493. Only set if you're running Voicebox on a different port.
# VOICEBOX_PORT=17493

# ──────────────────────────────────────────────────────────────────────────────
# VOICEBOX AUTO-START SETTINGS
# ──────────────────────────────────────────────────────────────────────────────
# These settings tell the pipeline where to find Voicebox so it can spawn the
# server automatically when the video pipeline needs voiceover. Without these,
# you must start Voicebox manually before running the pipeline.
# ==============================================================================

# Path to the cloned Voicebox repository root
# VOICEBOX_BACKEND_DIR=C:/one/voicebox

# Path to the Python interpreter inside Voicebox's virtual environment
# VOICEBOX_PYTHON=C:/one/voicebox/.venv/Scripts/python.exe

# ⚠️ NOTE: The pipeline clears PYTHONPATH when spawning Voicebox so the
# server uses its own CUDA-capable pytorch (not the system/CPU version).

# Local XTTS API Config (Free Open-Source Local Voice Cloning)
# XTTS_API_URL=http://localhost:8020
# XTTS_SPEAKER_WAV=cloned_speaker.wav
# XTTS_LANGUAGE=en

# Local OpenAI-Compatible / Kokoro-FastAPI Config (Free local synthesis)
# OPENAI_LOCAL_TTS_URL=http://localhost:8880/v1
# OPENAI_LOCAL_TTS_VOICE=af_sky
# OPENAI_LOCAL_TTS_MODEL=kokoro
# OPENAI_LOCAL_TTS_API_KEY=mock-key


# 🎵 AGENTIC PIPELINE TUNING
# ------------------------------------------------------------------------------
# Auto-resolve free background music when no music is specified (default: true)
# AUTO_FREE_MUSIC=true
# FFmpeg timeout per operation (ms, default: 30000)
# AGENTIC_FFMPEG_TIMEOUT_MS=30000
# FFprobe timeout per probe (ms, default: 15000)
# AGENTIC_FFPROBE_TIMEOUT_MS=15000
# Passing confidence for asset verification (1-10, default: 7)
# VERIFY_PASS=7


# 📥 DOWNLOAD TUNING
# ------------------------------------------------------------------------------
# Maximum bytes per media download (default: 150MB)
# MAX_DOWNLOAD_BYTES=157286400
# Download stall timeout in ms (default: 30000)
# DOWNLOAD_STALL_TIMEOUT_MS=30000


# ▶️ YOUTUBE UPLOAD
# ------------------------------------------------------------------------------
# Access token for YouTube Data API v3 upload
# YOUTUBE_ACCESS_TOKEN=


# ==============================================================================
# 👋 Tip: Copy this file to .env and fill in your actual API keys.
# ==============================================================================
