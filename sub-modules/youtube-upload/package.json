{
    "name": "youtube-upload-adapter",
    "version": "0.1.0",
    "private": true,
    "description": "Standalone YouTube upload adapter for Automated Video Generator. Built and verified in isolation before merging into the main project.",
    "type": "module",
    "bin": {
        "yt-upload": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "start": "tsx src/cli.ts",
        "test": "tsx --test \"src/**/*.test.ts\""
    },
    "dependencies": {
        "googleapis": "^144.0.0",
        "open": "^10.1.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
